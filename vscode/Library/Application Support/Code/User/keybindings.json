// Place your key bindings in this file to override the defaults
[
  {
    "key": "ctrl+j",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickOpen",
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen",
  },
  {
    "key": "ctrl+shift+b",
    "command": "workbench.action.browser.open",
  },
  {
    "key": "tab",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetVisible",
  },
  {
    "key": "shift+tab",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetVisible",
  },
  {
    "key": "ctrl+space",
    "command": "editor.action.triggerSuggest",
    "when": "editorTextFocus",
  },
  {
    "key": "ctrl+shift+g",
    "command": "-workbench.view.scm",
    "when": "workbench.scm.active",
  },
  {
    "key": "shift+cmd+g",
    "command": "workbench.view.scm",
  },
  {
    "key": "shift+cmd+o",
    "command": "outline.focus",
  },
  {
    "key": "cmd+d",
    "command": "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup",
    "when": "!activeEditorGroupEmpty",
  },
  {
    "key": "ctrl+tab",
    "command": "-workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup",
    "when": "lactiveEditorGroupEmpty",
  },
  {
    "key": "cmd+shift+/",
    "command": "workbench.view.extension.claude-sidebar-secondary",
  },
  {
    "key": "cmd+shift+,",
    "command": "workbench.view.extension.continue",
  },
  {
    "key": "cmd+shift+r",
    "command": "workbench.action.tasks.runTask",
  },
  {
    "key": "i",
    "command": "list.find",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "space /",
    "command": "editor.action.commentLine",
    "when": "(vim.mode == 'Normal' || vim.mode == 'Visual' || vim.mode == 'VisualLine') && editorTextFocus",
  },
  {
    "key": "space \\",
    "command": "workbench.action.splitEditorRight",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space -",
    "command": "workbench.action.splitEditorDown",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space q",
    "command": "workbench.action.closeActiveEditor",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "shift+;",
    "command": "vim.showQuickpickCmdLine",
    "when": "editorTextFocus && vim.mode != 'Insert'",
  },
  {
    "key": "space r t",
    "command": "workbench.action.tasks.runTask",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // {
  //   "key": "space e",
  //   "command": "workbench.action.toggleSidebarVisibility",
  //   "when": "vim.mode == 'Normal' && !terminalFocus && sideBarVisible && explorerViewletVisible",
  // },
  // {
  //   "key": "space e",
  //   "command": "workbench.view.explorer",
  //   "when": "vim.mode == 'Normal' && !terminalFocus && (!sideBarVisible || !explorerViewletVisible)",
  // },
  {
    "key": "space f b",
    "command": "workbench.action.quickOpenPreviousRecentlyUsedEditor",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space s",
    "command": "workbench.action.files.save",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space f l",
    "command": "actions.find",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space f f",
    "command": "workbench.action.findInFiles",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space space",
    "command": "workbench.action.quickOpen",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "ctrl+h",
    "command": "workbench.action.focusLeftGroup",
    "when": "!inputFocus",
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.focusRightGroup",
    "when": "!inputFocus",
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.focusBelowGroup",
    "when": "!inputFocus",
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.focusAboveGroup",
    "when": "!inputFocus",
  },
  {
    "key": "space g g",
    "command": "lazygit.openLazygit",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space d u",
    "command": "workbench.view.debug",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "enter",
    "command": "list.select",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "r",
    "command": "renameFile",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "d",
    "command": "deleteFile",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "y",
    "command": "filesExplorer.copy",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "x",
    "command": "filesExplorer.cut",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "a",
    "command": "explorer.newFile",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "p",
    "command": "filesExplorer.paste",
    "when": "filesExplorerFocus && !inputFocus",
  },
  {
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": {
      "text": "\u001b\r",
    },
    "when": "terminalFocus",
  },
]
